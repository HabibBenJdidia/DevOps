pipeline {
    agent any
    stages {
        stage('GIT') {
            steps {
                git branch: 'master', url: 'https://github.com/HabibBenJdidia/DevOps.git'
            }
        }
        stage('compile') {
            steps {
                sh 'mvn clean compile'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar'
                }
            }
        }
    }
}
